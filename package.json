{
  "name": "pcc",
  "private": true,
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "npm run rebuild"
  },
  "build": {
    "appId": "com.pkozuch.pcc",
    "productName": "PCC",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "dir"
    }
  },
